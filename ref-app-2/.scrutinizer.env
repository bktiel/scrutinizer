# Scrutinizer Pre-Commit Hook Configuration
# Copy this file to .scrutinizer.env in your project root and customize the values

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# The base URL of the Scrutinizer API
# Example: http://scrutinizer-api.example.com:8080
SCRUTINIZER_API_URL=http://localhost:8080

# The UUID of the policy to evaluate against
# Get this from the Scrutinizer dashboard
SCRUTINIZER_POLICY_ID=a2947298

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Project ID for tracking and reporting (optional)
# If not set, only the policy check will be performed
# SCRUTINIZER_PROJECT_ID=

# Application name for the API request (optional)
# If not set, defaults to the git repository name
# SCRUTINIZER_APP_NAME=my-service

# Path to the SBOM file (optional)
# If not found, the hook will attempt to generate one using cdxgen
# SCRUTINIZER_SBOM_PATH=./sbom.json

# Whether to fail the commit on WARN decisions (optional)
# By default, only FAIL decisions block commits
# Set to "true" to also block on warnings
# SCRUTINIZER_FAIL_ON_WARN=false

# Escape hatch to disable the hook entirely (optional)
# Set to "true" to skip the Scrutinizer check
# Useful for emergency commits or debugging
# SCRUTINIZER_SKIP_HOOK=false

# ============================================================================
# NOTES
# ============================================================================

# The hook performs these checks:
#   1. Detects if dependency files changed (pom.xml, package.json, etc.)
#   2. If no changes: exits immediately (fast path, zero overhead)
#   3. If changes detected: sends SBOM to Scrutinizer API for evaluation
#   4. Blocks commit if policy is violated (FAIL decision)
#   5. Optionally blocks on warnings (if SCRUTINIZER_FAIL_ON_WARN=true)

# Environment variable precedence:
#   1. Environment variables (set in shell before git commit)
#   2. Values in .scrutinizer.env (this file)
#   3. Defaults (built into the hook script)

# To skip the hook for a single commit:
#   SCRUTINIZER_SKIP_HOOK=true git commit -m "Emergency commit"

# To use a different config file location:
#   Create a symlink or source it from .scrutinizer.env
